PORT=3333
MONGODB_URI=mongodb://127.0.0.1:27017/ai-interview-coach
# Optional: override DB name if not included in URI
# MONGODB_DB=
BETTER_AUTH_SECRET=replace-with-long-random-string
BETTER_AUTH_URL=http://localhost:3333
FRONTEND_URL=http://localhost:3000

# Gemini (POST /sessions/start generates questions via Google Generative AI)
# https://aistudio.google.com/apikey — use one of these variable names:
GEMINI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# Skip LLM entirely (offline): USE_MOCK_AI=true

# Use only with a replica set deployment
# MONGO_TRANSACTIONS=true
